{
  "schemaVersion": 1,
  "id": "logicloom",
  "version": "${version}",
  "name": "LogicLoom",
  "description": "A mod that builds logic circuits using redstone",
  "authors": ["MightyFilipns"],
  "contact": {
    "issues": "https://github.com/MightyFilipns/LogicLoom/issues",
    "sources": "https://github.com/MightyFilipns/LogicLoom"
  },
  "license": "MIT",
  "icon": "assets/logicloom/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "com.mightyfilipns.logicloom.client.LogicLoomDataGenerator"
    ],
    "client": [
      "com.mightyfilipns.logicloom.client.LogicLoomClient"
    ],
    "main": [
      "com.mightyfilipns.logicloom.LogicLoom"
    ]
  },
  "mixins": [
    "logicloom.mixins.json",
    {
      "config": "logicloom.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
