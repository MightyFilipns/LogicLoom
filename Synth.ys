read_verilog my_design.v

synth
splitnets -ports
muxcover
opt -sat -full
abc
dfflegalize -cell $_DFF_P_ 0 -cell $_DFFE_PP_ 0 -cell $_DLATCH_P_ 0
stat
write_json mc_chip_maker.json
